<div class="checkout-page">
    <div class="page-header">
        <h1>Checkout</h1>
        <div class="breadcrumb">
            <a href="/">Home</a> / <a href="/cart">Cart</a> / <span>Checkout</span>
        </div>
    </div>
    
    <div class="checkout-layout">
        <div class="checkout-form-section">
            <form id="checkout-form" action="/orders" method="POST" enctype="multipart/form-data" data-loading-submit="1" data-loading-text="Placing Order...">
                <input type="hidden" name="orderNonce" value="<%= checkoutNonce %>">
                <% if (!currentUser) { %>
                    <div class="checkout-section">
                        <h3>Account Information</h3>
                        <p>Already have an account? <a href="/login">Login here</a></p>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="email">Email Address *</label>
                                <input type="email" id="email" name="email" required>
                            </div>
                        </div>
                    </div>
                <% } %>
                
                <div class="checkout-section">
                    <h3>Shipping Information</h3>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="fullName">Full Name *</label>
                            <input type="text" id="fullName" name="fullName" 
                                value="<%= currentUser ? currentUser.name : '' %>" required>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="phone">Phone Number *</label>
                            <input type="tel" id="phone" name="phone" 
                                value="<%= currentUser ? currentUser.phone : '' %>" required>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="address">Shipping Address *</label>
                        <textarea id="address" name="address" rows="3" required><%= currentUser ? currentUser.address : '' %></textarea>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="city">City *</label>
                            <input type="text" id="city" name="city" value="Lilongwe" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="postalCode">Postal Code</label>
                            <input type="text" id="postalCode" name="postalCode">
                        </div>
                    </div>
                </div>
                
                <div class="checkout-section">
                    <h3>Payment Instructions</h3>
                    <p>Use the payment details below, then place your order. Our team will confirm your payment manually.</p>

                    <div class="payment-admin-info">
                        <div class="payment-admin-row"><strong>Bank Name:</strong> <span><%= paymentSettings?.bank_name || 'Not configured' %></span></div>
                        <div class="payment-admin-row"><strong>Account Name:</strong> <span><%= paymentSettings?.bank_account_name || 'Not configured' %></span></div>
                        <div class="payment-admin-row"><strong>Account Number:</strong> <span><%= paymentSettings?.bank_account_number || 'Not configured' %></span></div>
                        <div class="payment-admin-row"><strong>Mobile Money:</strong> <span><%= paymentSettings?.mobile_money_provider || 'Not configured' %></span></div>
                        <div class="payment-admin-row"><strong>Code/Number:</strong> <span><%= paymentSettings?.mobile_money_code || 'Not configured' %></span></div>
                        <div class="payment-admin-row"><strong>Inquiries Phone:</strong> <span><%= paymentSettings?.inquiry_phone || 'Not configured' %></span></div>
                        <div class="payment-admin-row"><strong>Inquiries Email:</strong> <span><%= paymentSettings?.inquiry_email || 'Not configured' %></span></div>
                        <% if (paymentSettings?.notes) { %>
                            <div class="payment-admin-notes"><%= paymentSettings.notes %></div>
                        <% } %>
                    </div>
                    
                    <div class="payment-options">
                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="shop_pay" checked>
                            <div class="payment-option-content">
                                <i class="fas fa-wallet"></i>
                                <span>Bank / Mobile Money Transfer</span>
                            </div>
                        </label>

                        <label class="payment-option">
                            <input type="radio" name="paymentMethod" value="cash_on_delivery">
                            <div class="payment-option-content">
                                <i class="fas fa-money-bill-wave"></i>
                                <span>Cash on Delivery</span>
                            </div>
                        </label>
                    </div>

                    <div class="form-group" id="payment-receipt-group">
                        <label for="paymentReceipt">Upload Transaction Receipt *</label>
                        <input type="file" id="paymentReceipt" name="paymentReceipt" accept=".jpg,.jpeg,.png,.webp,image/*">
                        <small>Required for bank/mobile money transfer.</small>
                    </div>
                </div>
                
                <div class="checkout-actions">
                    <a href="/cart" class="btn btn-outline">Back to Cart</a>
                    <button type="submit" class="btn">Place Order</button>
                </div>
            </form>
        </div>
        
        <div class="order-summary-section">
            <div class="order-summary">
                <h3>Order Summary</h3>
                
                <div class="order-items">
                    <% cart.forEach(item => { %>
                        <div class="order-item">
                            <div class="item-image">
                                <img src="<%= item.image_url %>" alt="<%= item.name %>">
                            </div>
                            <div class="item-details">
                                <h4><%= item.name %></h4>
                                <p>Qty: <%= item.quantity %></p>
                            </div>
                            <div class="item-price">
                                MK <%= (item.price * item.quantity).toLocaleString() %>
                            </div>
                        </div>
                    <% }) %>
                </div>
                
                <div class="order-totals">
                    <div class="total-row">
                        <span>Subtotal:</span>
                        <span>MK <%= total.toLocaleString() %></span>
                    </div>
                    <div class="total-row">
                        <span>Shipping:</span>
                        <span>MK 0.00</span>
                    </div>
                    <div class="total-row">
                        <span>Tax:</span>
                        <span>MK 0.00</span>
                    </div>
                    <div class="total-row grand-total">
                        <span>Total:</span>
                        <span>MK <%= total.toLocaleString() %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="processing-popup" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:4000;align-items:center;justify-content:center;">
    <div style="background:#fff;padding:1.1rem 1.25rem;border-radius:10px;min-width:260px;text-align:center;box-shadow:0 12px 30px rgba(0,0,0,0.25);">
        <h4 style="margin:0 0 0.5rem 0;color:var(--primary);">Order being processed</h4>
        <p id="processing-message" style="margin:0;color:var(--gray);">Please wait...</p>
    </div>
</div>
