<!-- Price Calculator for Admins -->
<div class="price-calculator-section">
    <div class="calculator-container">
        <h2>Product Price Calculator</h2>
        <p class="calculator-description">Calculate the final selling price based on original price, profit margin, forex rate, and transport costs.</p>
        
        <div class="calculator-form">
            <div class="form-group">
                <label for="origPrice">Original Price (Product Cost)</label>
                <input 
                    type="number" 
                    id="origPrice" 
                    placeholder="e.g., 50000" 
                    step="0.01"
                    min="0"
                    class="form-control calculator-input">
                <small>Enter the base cost of the product</small>
            </div>

            <div class="form-group">
                <label for="forexRate">Forex Rate (Exchange Rate)</label>
                <input 
                    type="number" 
                    id="forexRate" 
                    placeholder="e.g., 1.05" 
                    step="0.01"
                    min="0"
                    class="form-control calculator-input"
                    value="1">
                <small>Multiply original price by this rate (e.g., USD to MWK)</small>
            </div>

            <div class="form-group">
                <label for="transportCost">Transport & Shipping Cost (Fixed)</label>
                <input 
                    type="number" 
                    id="transportCost" 
                    placeholder="e.g., 5000" 
                    step="0.01"
                    min="0"
                    class="form-control calculator-input">
                <small>Fixed cost per unit for transport and handling</small>
            </div>

            <div class="form-group">
                <label for="profitPercent">Profit Margin (%)</label>
                <input 
                    type="number" 
                    id="profitPercent" 
                    placeholder="e.g., 25" 
                    step="0.1"
                    min="0"
                    class="form-control calculator-input">
                <small>Desired profit as percentage of base cost (e.g., 25%)</small>
            </div>
        </div>

        <div class="calculator-results">
            <div class="result-card">
                <div class="result-row">
                    <span class="result-label">Original Price:</span>
                    <span class="result-value" id="resultOrigPrice">0.00</span>
                </div>
                <div class="result-row">
                    <span class="result-label">Forex Adjusted:</span>
                    <span class="result-value" id="resultForexPrice">0.00</span>
                </div>
                <div class="result-row">
                    <span class="result-label">Transport Cost:</span>
                    <span class="result-value" id="resultTransportCost">0.00</span>
                </div>
                <div class="result-row">
                    <span class="result-label">Subtotal (before profit):</span>
                    <span class="result-value" id="resultSubtotal">0.00</span>
                </div>
                <div class="result-row profit-row">
                    <span class="result-label">Profit Amount:</span>
                    <span class="result-value" id="resultProfitAmount">0.00</span>
                </div>
                <div class="result-row final-row">
                    <span class="result-label"><strong>Final Selling Price:</strong></span>
                    <span class="result-value final-value" id="resultFinalPrice">0.00</span>
                </div>
            </div>
        </div>

        <div class="calculator-actions">
            <button type="button" class="btn btn-primary" id="resetCalcBtn">Reset</button>
            <button type="button" class="btn btn-secondary" id="copyPriceBtn">Copy Final Price</button>
        </div>

        <div class="calculator-formula">
            <h4>Formula Used:</h4>
            <code>Final Price = (Original Price × Forex Rate + Transport Cost) × (1 + Profit % / 100)</code>
        </div>
    </div>
</div>

