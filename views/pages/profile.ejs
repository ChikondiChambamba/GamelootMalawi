<section class="profile-section">
  <div class="container">
    <div class="profile-header">
      <h2>Welcome, <%= user.name %></h2>
      <p>Email: <%= user.email %></p>
      <p>Role: <%= user.role %></p>
    </div>

    <div class="profile-content">
      <div class="profile-card">
        <h3>Your Cart</h3>
        <% if (cart && cart.length > 0) { %>
          <table class="cart-table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% cart.forEach(item => { %>
                <tr>
                  <td class="cart-product">
                    <img src="<%= item.image_url %>" alt="<%= item.name %>" class="cart-thumb" />
                    <div class="cart-product-info">
                      <strong><%= item.name %></strong>
                      <div class="cart-product-meta"><%= item.sku ? item.sku : '' %></div>
                    </div>
                  </td>
                  <td><%= item.quantity %></td>
                  <td>MK <%= item.price.toLocaleString() %></td>
                  <td>MK <%= (item.price * item.quantity).toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <div class="cart-summary">
            <div class="cart-total">
              <span>Total:</span>
              <strong>MK <%= (cartTotal).toLocaleString() %></strong>
            </div>
            <div class="cart-actions">
              <a href="/cart" class="btn">Manage Cart</a>
              <a href="/checkout" class="btn btn-outline">Proceed to Checkout</a>
            </div>
          </div>
        <% } else { %>
          <p>Your cart is empty. <a href="/shop">Shop now</a>.</p>
        <% } %>
      </div>

      <div class="profile-card">
        <h3>Account</h3>
        <p>Name: <%= user.name %></p>
        <p>Email: <%= user.email %></p>
        <p>Joined: <%= user.created_at ? user.created_at : 'N/A' %></p>
      </div>
    </div>
  </div>
</section>
