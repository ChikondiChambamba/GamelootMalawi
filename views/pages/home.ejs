<!-- Hero section -->
<section class="hero">
    <button class="hero-controller" type="button" aria-label="Catch me and win a reward">
        <span class="hero-controller-icon"><i class="fas fa-gamepad"></i></span>
        <span class="hero-controller-text">Catch me and win a reward</span>
    </button>
    <div class="hero-content">
        <h2>PREMIUM GAMING EXPERIENCE IN MALAWI</h2>
        <p>Discover the latest PlayStation consoles, games, accessories, and top electronics at unbeatable prices. Elevate your gaming setup today!</p>
        <a href="/shop" class="btn">Shop Now</a>
        <a href="/shop?category=deals" class="btn btn-outline">View Deals</a>
    </div>
</section>

<!-- Categories section -->
<section class="category-arc-section" id="category-arc-section">
    <div class="section-title">
        <h2>Shop By Category</h2>
        <p>Find exactly what you need from our carefully curated collections</p>
        <p>The Premium selection of gaming products</p>
    </div>

    <div class="category-arc-track" id="category-arc-track" aria-label="Shop by category carousel">
        <% categories.forEach((category, index) => { %>
            <article class="category-arc-card" data-category-card style="--index:<%= index %>;">
                <div class="category-arc-icon-wrap">
                    <i class="<%= category.icon %> category-arc-icon"></i>
                </div>
                <h3><%= category.name %></h3>
                <p><%= category.description %></p>
                <a href="/category/<%= category.slug %>" class="category-arc-btn">Shop Now</a>
            </article>
        <% }) %>
    </div>
</section>

<!-- Featured Products section -->
<section class="products">
    <div class="products-header">
        <div class="section-title" style="text-align: left; margin-bottom: 0;">
            <h2>Featured Products</h2>
            <p>Our handpicked premium selections</p>
        </div>
    </div>
    
    <div class="products-grid">
        <% if (featuredProducts.length > 0) { %>
            <% featuredProducts.forEach(product => { %>
                <div class="product-card animate-on-scroll" data-product-id="<%= product.id %>" data-product-category="<%= product.category_name.toLowerCase() %>">
                    <% if (product.badge && product.badge !== 'none') { %>
                        <span class="product-badge <%= product.badge %>">
                            <%= product.badge.charAt(0).toUpperCase() + product.badge.slice(1) %>
                        </span>
                    <% } %>
                    <button class="product-cart-icon" type="button" data-product-id="<%= product.id %>" aria-label="Add <%= product.name %> to cart">
                        <i class="fas fa-shopping-cart"></i>
                    </button>
                    
                    <div class="product-img">
                        <img src="<%= product.image_url %>" alt="<%= product.name %>">
                    </div>
                    
                    <div class="product-content">
                        <span class="product-category"><%= product.category_name %></span>
                        <h3 class="product-title"><%= product.name %></h3>
                        
                        <div class="product-price">
                            <span class="current-price">MK <%= product.price.toLocaleString() %></span>
                            <% if (product.original_price && product.original_price > product.price) { %>
                                <span class="original-price">MK <%= product.original_price.toLocaleString() %></span>
                            <% } %>
                        </div>
                        
                        <div class="product-actions">
                            <button class="action-btn shop-now-btn" data-product-id="<%= product.id %>">
                                Shop Now
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="no-products">No featured products available at the moment.</p>
        <% } %>
    </div>
</section>

<!-- All Products section -->
<section class="products">
    <div class="products-header">
        <div class="section-title" style="text-align: left; margin-bottom: 0;">
            <h2>Latest Products</h2>
            <p>Browse our newest arrivals</p>
        </div>
        
        <div class="filter-controls">
            <button class="filter-btn active" data-filter="all">All Products</button>
            <button class="filter-btn" data-filter="consoles">Consoles</button>
            <button class="filter-btn" data-filter="games">Games</button>
            <button class="filter-btn" data-filter="accessories">Accessories</button>
            <button class="filter-btn" data-filter="electronics">Electronics</button>
            <button class="filter-btn" data-filter="sale">On Sale</button>
        </div>
    </div>
    
    <div class="products-grid">
        <% if (allProducts.length > 0) { %>
            <% allProducts.forEach(product => { %>
                <div class="product-card animate-on-scroll" data-product-id="<%= product.id %>">
                    <% if (product.badge && product.badge !== 'none') { %>
                        <span class="product-badge <%= product.badge %>">
                            <%= product.badge.charAt(0).toUpperCase() + product.badge.slice(1) %>
                        </span>
                    <% } %>
                    <button class="product-cart-icon" type="button" data-product-id="<%= product.id %>" aria-label="Add <%= product.name %> to cart">
                        <i class="fas fa-shopping-cart"></i>
                    </button>
                    
                    <div class="product-img">
                        <img src="<%= product.image_url %>" alt="<%= product.name %>">
                    </div>
                    
                    <div class="product-content">
                        <span class="product-category"><%= product.category_name %></span>
                        <h3 class="product-title"><%= product.name %></h3>
                        
                        <div class="product-price">
                            <span class="current-price">MK <%= product.price.toLocaleString() %></span>
                            <% if (product.original_price && product.original_price > product.price) { %>
                                <span class="original-price">MK <%= product.original_price.toLocaleString() %></span>
                            <% } %>
                        </div>
                        
                        <div class="product-actions">
                            <button class="action-btn shop-now-btn" data-product-id="<%= product.id %>">
                                Shop Now
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="no-products">No products available at the moment.</p>
        <% } %>
    </div>
    
    <div class="view-all-container" style="text-align: center; margin-top: 3rem;">
        <a href="/shop" class="btn">View All Products</a>
    </div>
</section>
