<div class="container-fluid py-4" data-admin-orders="1">
  <div class="row mb-4">
    <div class="col">
      <h2>Order Management</h2>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Order #</th>
          <th>Customer</th>
          <th>Total (MWK)</th>
          <th>Status</th>
          <th>Created At</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <tr>
              <td><%= order.order_number || ('#' + order.id) %></td>
              <td><%= order.customer_name %> (<%= order.customer_email %>)</td>
              <td>MWK <%= (order.total_amount || 0).toLocaleString() %></td>
              <td><span class="badge <%= order.status === 'delivered' ? 'bg-success' : (order.status === 'cancelled' ? 'bg-danger' : 'bg-secondary') %>"><%= order.status || 'pending' %></span></td>
              <td><%= new Date(order.created_at).toLocaleString() %></td>
              <td>
                <button class="btn btn-sm btn-primary view-order" data-order-id="<%= order.id %>">View</button>
                <button class="btn btn-sm btn-secondary change-status" data-order-id="<%= order.id %>">Change Status</button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6">No orders found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

